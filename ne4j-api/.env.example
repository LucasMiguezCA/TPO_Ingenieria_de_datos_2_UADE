# Puerto en el que escucha la API de Neo4j (por defecto 3001)
PORT=3001

# 🔗 Configuración de la base de datos Neo4j
# Para entorno local suele ser bolt://localhost:7687 o neo4j://localhost:7687
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=pictolink

# 🌐 Orígenes permitidos por CORS, separados por comas.
# Como la API de Redis (puerto 4000) le hace peticiones HTTP directamente, 
# deberías incluirla si decidís restringir los accesos. Vacío permite todo (*).
