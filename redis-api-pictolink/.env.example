# Copiá este archivo a .env y completá tus valores.
# Se carga solo con `npm start` (usa node --env-file-if-exists=.env).
# El .env real va en .gitignore: nunca se commitea.

# URL de Redis:
#   - Local:  redis://localhost:6379
#   - Nube (Redis Cloud / Upstash, con TLS):  rediss://default:TU_PASSWORD@HOST:PUERTO
REDIS_URL=redis://localhost:6379

# URL de la API de Neo4j (ne4j-api/server.js). Default :3001 desde el fix de puertos.
NEO_API_URL=http://localhost:3001

# Puerto en el que escucha esta API de Redis.
PORT=4000
