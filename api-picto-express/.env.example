# Copiá este archivo a .env y completá tus valores.
# El .env real va en .gitignore: nunca se commitea.

# Puerto en el que escucha esta API de Mongo.
PORT=3000

# URI de conexión a MongoDB (local por defecto).
MONGO_URI=mongodb://127.0.0.1:27017/picto_mongodb

# Orígenes permitidos por CORS, separados por coma. Vacío = abierto (*).
# Ej: CORS_ORIGINS=http://localhost:5500,http://localhost:3000
CORS_ORIGINS=

# Secreto para firmar/verificar los JWT.
# IMPORTANTE: debe ser EXACTAMENTE el mismo valor que en redis-api-pictolink/.env.
JWT_SECRET=dev-secret-pictolink

# Clave para llamadas internas entre APIs (Redis -> Mongo: hidratar listas y writeback).
# IMPORTANTE: debe ser EXACTAMENTE el mismo valor que en redis-api-pictolink/.env.
SERVICE_KEY=dev-service-pictolink

# Activa la exigencia de token en las rutas protegidas.
#   - sin definir / cualquier valor distinto de 'true'  -> auth APAGADA (no exige token).
#   - 'true'                                            -> exige "Authorization: Bearer <token>" (o X-Service-Key interno).
AUTH_REQUIRED=false